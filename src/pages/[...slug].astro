---
import Layout from "../layouts/Layout.astro";
import { ContentPage } from "../components/Site.jsx";
import { pages } from "../data/siteContent.js";

export function getStaticPaths() {
  return Object.entries(pages).map(([path, page]) => ({
    params: { slug: path.replace(/^\/|\/$/g, "") },
    props: { path, page }
  }));
}

const { path, page } = Astro.props;
---

<Layout title={page.title} description={page.description} canonical={path}>
  <ContentPage page={page} client:load />
</Layout>
