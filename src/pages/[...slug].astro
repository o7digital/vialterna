---
import Layout from "../layouts/Layout.astro";
import { ContentPage } from "../components/Site.jsx";
import { pages } from "../data/siteContent.js";

export function getStaticPaths() {
  return Object.entries(pages).map(([path, page]) => ({
    params: { slug: path.replace(/^\/|\/$/g, "") },
    props: { path, page }
  }));
}

const { path, page } = Astro.props;

const hubRedirects = {
  "/soluciones/": "/soluciones/conectividad-sitios-distribuidos/",
  "/industrias/": "/industrias/servicios-financieros/"
};

if (hubRedirects[path]) {
  return Astro.redirect(hubRedirects[path], 301);
}
---

<Layout title={page.title} description={page.description} canonical={path}>
  <ContentPage page={page} path={path} client:load />
</Layout>
